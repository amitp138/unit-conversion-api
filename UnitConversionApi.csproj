<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Exclude the test project directory from the main project's build -->
    <Compile Remove="UnitConversionApi.Tests\**" />
    <Content Remove="UnitConversionApi.Tests\**" />
    <EmbeddedResource Remove="UnitConversionApi.Tests\**" />
    <None Remove="UnitConversionApi.Tests\**" />
  </ItemGroup>

</Project>
